<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="asmeta" nsURI="http://org.asmeta/TemporalProperties#ASMETA"
    nsPrefix="AsmM">
  <eSubpackages name="definitions" nsURI="http://org.asmeta/TemporalProperties#Definitions"
      nsPrefix="AsmM">
    <eClassifiers xsi:type="ecore:EClass" name="TemporalProperty" abstract="true"
        eSuperTypes="AsmM.ecore#//definitions/Property"/>
    <eClassifiers xsi:type="ecore:EClass" name="CtlSpec" eSuperTypes="#//definitions/TemporalProperty">
      <eStructuralFeatures xsi:type="ecore:EReference" name="body" ordered="false"
          lowerBound="1" eType="ecore:EClass AsmM.ecore#//terms/basicterms/Term" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="LtlSpec" eSuperTypes="#//definitions/TemporalProperty">
      <eStructuralFeatures xsi:type="ecore:EReference" name="body" ordered="false"
          lowerBound="1" eType="ecore:EClass AsmM.ecore#//terms/basicterms/Term" containment="true"/>
    </eClassifiers>
  </eSubpackages>
</ecore:EPackage>
